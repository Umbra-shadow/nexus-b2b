# App
NEXTAUTH_SECRET=your-secret-here-min-32-chars
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Platform admin (the email that gets access to /admin)
PLATFORM_ADMIN_EMAIL=you@yourdomain.com

# Aurora PostgreSQL (AWS RDS)
DATABASE_URL=postgresql://user:password@cluster.us-east-1.rds.amazonaws.com:5432/nexusb2b

# AWS Credentials (used for DynamoDB, S3, and SES)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# DynamoDB
DYNAMODB_TABLE_MESSAGES=nexusb2b_messages

# S3
S3_BUCKET_NAME=nexusb2b-uploads
S3_BUCKET_REGION=us-east-1

# SES (email sending)
SES_FROM_EMAIL=no-reply@nexusb2b.io
SES_FROM_NAME=NexusB2B

# Google Gemini (AI)
GEMINI_API_KEY=AIza...

# Encryption key for bank details (32-byte hex = 64 chars)
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here
