# App
NEXTAUTH_SECRET=generate-with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Platform admin (the email that gets access to /admin)
PLATFORM_ADMIN_EMAIL=you@yourdomain.com

# Aurora PostgreSQL (AWS RDS)
DATABASE_URL=postgresql://user:password@cluster.us-east-1.rds.amazonaws.com:5432/nexusb2b

# AWS Credentials (DynamoDB + S3 + SES)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# DynamoDB
DYNAMODB_TABLE_MESSAGES=nexusb2b_messages

# S3
S3_BUCKET_NAME=your-s3-bucket-name
S3_BUCKET_REGION=us-east-1

# SES (email sending — sender must be verified in AWS SES)
SES_FROM_EMAIL=no-reply@yourdomain.com
SES_FROM_NAME=NexusB2B

# AI — Vercel v0 API key (from v0.dev)
V0_API_KEY=v1:team_...

# Encryption key for bank details (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=your-64-char-hex-key-here
